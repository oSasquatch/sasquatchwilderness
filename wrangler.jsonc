{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sasquatchwilderness",
  "main": "_worker.js",
  "compatibility_date": "2026-04-19",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
